{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist/src",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "src/*": ["src/*"],
      "@toss/shared": ["../packages/toss-shared/dist/index.d.ts"],
      "@toss/shared/*": ["../packages/toss-shared/dist/*"],
      "@davinci/similarity": ["../packages/similarity/dist/index.d.ts"],
      "@davinci/similarity/*": ["../packages/similarity/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
