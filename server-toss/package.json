{
  "name": "server-toss",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "npx rimraf dist",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "seed": "mikro-orm schema:update --run --safe --config ./src/mikro-orm.config.ts && mikro-orm seeder:run --config ./src/mikro-orm.config.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./jest-integration.json --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:down": "npx mikro-orm migration:fresh",
    "seed:drawing:small": "npx mikro-orm seeder:run --class=SmallUserDrawingSeeder",
    "seed:drawing:small:fresh": "npx mikro-orm migration:fresh --seed SmallUserDrawingSeeder",
    "seed:drawing:large": "npx mikro-orm seeder:run --class=LargeUserDrawingSeeder",
    "seed:ranking": "npx mikro-orm seeder:run --class=RankingSeeder",
    "chance:reset": "bash scripts/reset-chance.sh",
    "migration:check": "mikro-orm migration:check",
    "migration:list": "mikro-orm migration:list",
    "migration:up": "mikro-orm migration:up",
    "migration:pending": "mikro-orm migration:pending",
    "migration:down": "mikro-orm migration:down",
    "migration:fresh": "mikro-orm migration:fresh",
    "load-test:docker:run": "docker compose -f tests/load-test/docker/compose.yml up -d --build",
    "load-test:docker:stop": "docker compose -f tests/load-test/docker/compose.yml down",
    "load-test:docker:logs": "docker compose -f tests/load-test/docker/compose.yml logs -f",
    "tokens:generate": "node ./tests/load-test/scripts/generate-test-tokens.js"
  },
  "dependencies": {
    "@davinci/similarity": "workspace:*",
    "@mikro-orm/core": "^7.0.8",
    "@mikro-orm/decorators": "^7.0.8",
    "@mikro-orm/migrations": "^7.0.8",
    "@mikro-orm/mysql": "^7.0.8",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/seeder": "7.0.10",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@toss/shared": "workspace:*",
    "cookie-parser": "^1.4.7",
    "nestjs-pino": "^4.5.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mikro-orm/cli": "^7.0.8",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "passWithNoTests": true,
    "setupFiles": [
      "<rootDir>/test-setup/setup-mikro-orm-mocks.ts",
      "<rootDir>/test-setup/setup-logger.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(\\.pnpm/)?(@mikro-orm))"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^@toss/shared$": "<rootDir>/../../packages/toss-shared/dist/index.js",
      "^@toss/shared/(.*)$": "<rootDir>/../../packages/toss-shared/dist/$1",
      "^@davinci/similarity$": "<rootDir>/../../packages/similarity/dist/index.js",
      "^@davinci/similarity/(.*)$": "<rootDir>/../../packages/similarity/dist/$1"
    }
  }
}
