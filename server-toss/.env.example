PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_PORT=3306
MYSQL_DATABASE=daVinci_toss
CORS_ORIGIN=http://localhost:5173
TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im
TOSS_API_KEY=TossApiKey
TOSS_DECRYPT_KEY=TossDecryptKey
TOSS_DECRYPT_AAD=TOSS
TOSS_CLIENT_CERT_PATH=./certs/davinci_new_public.crt
TOSS_CLIENT_KEY_PATH=./certs/davinci_new_private.key
JWT_SECRET=32자 이상 문자열
PROMOTION_CODE=TEMP_PROMOTION_CODE
# 공유 적립 일일 캡 (자정 KST 리셋, contactsViral + share 폴백 합쳐서). 광고는 일일 캡 없음(무제한)
SHARE_DAILY_CHARGE_LIMIT=5
# 콘솔 인앱광고에 등록한 광고 그룹 ID 콤마 구분
AD_GROUP_ID_WHITELIST=
# 콘솔 공유 리워드에 등록한 모듈 ID 콤마 구분 (moduleId가 곧 리워드 ID)
SHARE_MODULE_ID_WHITELIST=
# 앱인토스 콘솔에서 발급받은 메시지 템플릿 코드 (기능성 알림)
TOSS_TEMPLATE_DAILY_PROMPT=
# 앱인토스 콘솔에서 발급받은 알림 동의문 템플릿 코드
TOSS_TEMPLATE_DAILY_PROMPT_AGREEMENT_CODE=
# 운영 발송 게이트. true일 때만 일일 제시 그림 알림 스케줄러가 실제 발송함
DAILY_PROMPT_NOTIFICATION_ENABLED=false

# 랭킹 추월(OVERTAKEN) 알림 관련. 사용자가 그림 제출로 TOP100 진입 시
# 추월된 동의자(일일 1회 limit)에게 발송.
TOSS_TEMPLATE_OVERTAKEN=
TOSS_TEMPLATE_OVERTAKEN_AGREEMENT_CODE=
# 운영 발송 게이트. true일 때만 RankingChangedListener가 실제 발송함
OVERTAKEN_NOTIFICATION_ENABLED=false

# IN_FLIGHT 잔존 row 자동 정리 임계 (분). 서버 크래시 등으로 굳은 row를
# FAILED로 강제 마킹해서 UNIQUE 차단으로 영원히 알림 못 받는 상황 방지.
# 매 시간 정각(KST)에 cleanup cron이 동작.
NOTIFICATION_STALE_THRESHOLD_MINUTES=60
