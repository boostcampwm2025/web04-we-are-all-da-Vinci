VITE_API_BASE_URL=/api
# 콘솔 공유 리워드에서 발급받은 모듈 ID. 비어 있으면 share 폴백
VITE_CONTACTS_VIRAL_MODULE_ID=
# 앱인토스 콘솔에서 발급받은 알림 동의문 템플릿 코드
VITE_TOSS_DAILY_PROMPT_AGREEMENT_TEMPLATE_CODE=
# 랭킹 추월 알림 동의문 (OVERTAKEN)
VITE_TOSS_OVERTAKEN_AGREEMENT_TEMPLATE_CODE=

# Firebase Web SDK (Analytics/GA4) 설정. 비어 있으면 GA4 fan-out 비활성화돼 토스 Analytics만 동작
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
